APP_ENV=development
TIMEZONE=Asia/Tokyo
BASE_URL=https://your-render-service.onrender.com
PORT=8000

# LINE Developers Console
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# First message from each user is automatically registered. Optionally prefill one ID.
DEFAULT_LINE_USER_ID=

# Google Sheets
GOOGLE_SHEET_ID=
# Local: path to JSON. Render: paste the complete service-account JSON on one line.
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=

# Scheduler (keep WEB_CONCURRENCY=1 on Render)
ENABLE_SCHEDULER=true
# Required when external free cron/GitHub Actions calls /tasks/*
CRON_SECRET=replace-with-a-long-random-string
MORNING_REMINDER_TIME=07:30
EVENING_REMINDER_TIME=22:00
WEEKLY_REPORT_TIME=22:30
WEIGHT_GOAL_KG=85
TARGET_DATE=2026-09-01
PROTEIN_TARGET_G=130
WATER_TARGET_L=3
